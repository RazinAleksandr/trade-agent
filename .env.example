# Polygon wallet private key (with 0x prefix)
PRIVATE_KEY=0x...

# OpenAI API key
OPENAI_API_KEY=sk-...

# Polymarket CLOB API
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Trading mode
PAPER_TRADING=true

# Risk parameters
MAX_POSITION_SIZE_USDC=50
MAX_TOTAL_EXPOSURE_USDC=200
MIN_EDGE_THRESHOLD=0.10
KELLY_FRACTION=0.25

# Web search for market analysis
ENABLE_WEB_SEARCH=true
