# Polymarket Autonomous Trading Agent Configuration
# Copy to .env and fill in required values

# === REQUIRED ===
# PRIVATE_KEY=your_ethereum_private_key  # Only needed for live trading

# === TRADING MODE ===
PAPER_TRADING=true  # Set to "false" for live trading (requires PRIVATE_KEY)

# === RISK PARAMETERS ===
MIN_EDGE_THRESHOLD=0.10      # Minimum edge to consider a trade (10%)
KELLY_FRACTION=0.25          # Quarter Kelly for conservative sizing
MAX_POSITION_SIZE_USDC=50    # Maximum single position size in USDC
MAX_TOTAL_EXPOSURE_USDC=200  # Maximum total portfolio exposure in USDC

# === MARKET DISCOVERY FILTERS ===
MIN_VOLUME_24H=1000          # Minimum 24h volume in USDC
MIN_LIQUIDITY=500            # Minimum liquidity in USDC
MAX_MARKETS_PER_CYCLE=10     # Maximum markets to return per discovery

# === API ENDPOINTS ===
POLYMARKET_HOST=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
CHAIN_ID=137                 # Polygon mainnet

# === DATABASE ===
DB_PATH=trading.db

# === LOGGING ===
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
LOG_FILE=trading.log         # Structured JSON log file

# === SCHEDULING ===
CYCLE_INTERVAL=4h               # Trading cycle interval (30m, 1h, 2h, 4h, 6h, 12h, 1d)
MIN_PAPER_CYCLES=10             # Minimum paper cycles before live trading gate opens
